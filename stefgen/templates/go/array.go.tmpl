	prevLen int
	elem {{.ElemType.Storage}}
	elemPtr *{{.ElemType.Storage}}
	//modifiedFields modifiedFields
}

func (e *{{ .ArrayName }}DecoderLastValElem) init() {
	//e.elem.init(&e.modifiedFields, 1)
	e.elemPtr = &e.elem
}

// Init is called once in the lifetime of the stream.
func (d *{{ .ArrayName }}Decoder) Init(state* ReaderState, columns *pkg.ReadColumnSet) error {
	// Remember this encoder in the state so that we can detect recursion.
	if state.{{ .ArrayName }}Decoder != nil {
		panic("cannot initialize {{ .ArrayName }}Decoder: already initialized")
	}
	state.{{ .ArrayName }}Decoder = d
	defer func() { state.{{ .ArrayName }}Decoder = nil }()

	d.column = columns.Column()

{{- if .ElemType.IsPrimitive}}
{{- if .ElemType.DictName}}
	err := d.decoder.Init(&state.{{.ElemType.DictName}}, columns.AddSubColumn())
{{- else if .ElemType.IsDictPossible}}
	err := d.decoder.Init(nil, columns.AddSubColumn())
{{- else}}
	err := d.decoder.Init(columns.AddSubColumn())
{{- end}}
	if err != nil {
		return err
	}
{{- else}}
	if state.{{.ElemType.EncoderType}}Decoder != nil {
		d.decoder = state.{{.ElemType.EncoderType}}Decoder
		d.isRecursive = true
	} else {
		d.decoder = new({{.ElemType.EncoderType}}Decoder)
		if err := d.decoder.Init(state, columns.AddSubColumn()); err != nil {
			return err
		}
	}
	//d.lastVal.init(nil,0)
{{- end}}

	d.lastValStack = make([]{{ .ArrayName }}DecoderLastValElem, 1)
	d.lastValStack[0].init()

	return nil
}

// Continue is called at the start of the frame to continue decoding column data.
// This should set the decoder's source buffer, so the new decoding continues from
// the supplied column data. This should NOT reset the internal state of the decoder,
// since columns can cross frame boundaries and the new column data is considered
// continuation of that same column in the previous frame.
func (d *{{ .ArrayName }}Decoder) Continue() {
	d.buf.Reset(d.column.Data())
	if !d.isRecursive {
		d.decoder.Continue()
	}
}

func (d *{{ .ArrayName }}Decoder) Reset() {
	if !d.isRecursive {
		d.decoder.Reset()
	}
	d.lastValStack = make([]{{ .ArrayName }}DecoderLastValElem, 1)
	d.lastValStack[0].init()
}

func (d *{{ .ArrayName }}Decoder) Decode(dst *{{.ArrayName}}) error {
	lastVal := &d.lastValStack[len(d.lastValStack)-1]
	d.lastValStack = append(d.lastValStack, {{ .ArrayName }}DecoderLastValElem{})
	d.lastValStack[len(d.lastValStack)-1].init()
	defer func() { d.lastValStack = d.lastValStack[:len(d.lastValStack)-1] }()

	lenDelta, err := d.buf.ReadVarintCompact()
	if err != nil {
		return err
	}

	newLen := lastVal.prevLen + int(lenDelta)

	dst.EnsureLen(newLen)

	lastVal.prevLen = newLen

	for i := 0; i < newLen; i++ {
		{{- if .ElemType.IsPrimitive}}
		err = d.decoder.Decode(&dst.elems[i])
		if err != nil {
			return err
		}
		{{- else}}
		err = d.decoder.Decode({{if .ElemType.Flags.StoreByPtr}}&{{end}}lastVal.elemPtr)
		if err != nil {
			return err
		}
		copy{{.ElemType.TypeName}}(dst.elems[i], lastVal.elemPtr)
		{{- end}}
	}

	return nil
}