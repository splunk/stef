        if (state.getOverrideSchema() != null) {
            int fieldCount = state.getOverrideSchema().fieldCount("{{ .StructName }}");
            this.fieldCount = fieldCount;
        } else {
            this.fieldCount = {{len .Fields}};
        }

        {{ range $i, $e := .Fields }}
        if (this.fieldCount <= {{$i}}) {
            return; // {{.Name}} and subsequent fields are skipped.
        }
        {{- if .IsPrimitive}}
            {{- if .Type.DictName}}
            this.{{.name}}Encoder.init(state.get{{.Type.DictName}}(), columns.addSubColumn());
            {{- else if .Type.IsDictPossible}}
            this.{{.name}}Encoder.init(null, columns.addSubColumn());
            {{- else}}
            this.{{.name}}Encoder.init(columns.addSubColumn());
            {{- end}}
        {{- else}}
        this.{{.name}}Encoder.init(state, columns.addSubColumn());
        {{- end}}
        {{- end}}
    }

    public void reset() {
        this.prevType = null;
        {{- range .Fields}}
        this.{{.name}}Encoder.reset();
        {{- end}}
    }

    // Encode encodes val into buf
    public void encode({{ .StructName }} val) {
        int typOrdinal = val.getType().ordinal();
        if (typOrdinal > this.fieldCount) {
            typOrdinal = 0; // Encode as None if not supported
        }
