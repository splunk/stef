use std::collections::HashMap;
use std::io::{self, Read};

use crate::*;
use crate::reader_state::ReaderState;

pub struct {{.StructName}}Reader<R: Read> {
    source: R,
    state: ReaderState,
    header: stef_core::FixedHeader,
    user_data: HashMap<String, String>,
    schema: Option<stef_core::schema::WireSchema>,

    pub record: {{.StructName}},
    record_count: u64,
}

impl<R: Read> {{.StructName}}Reader<R> {
    const MAX_RECORD_SIZE: usize = 64 * 1024 * 1024;

    pub fn new(source: R) -> Result<Self, stef_core::errors::StefError> {
        let mut state = ReaderState::default();
        state.init(None);

        Ok(Self {
            source,
            state,
            header: stef_core::FixedHeader::default(),
            user_data: HashMap::new(),
            schema: None,
            record: {{.StructName}}::default(),
            record_count: 0,
        })
    }

    pub fn init_schema(&mut self) -> Result<(), stef_core::errors::StefError> {
        Ok(())
    }

    pub fn header(&self) -> &stef_core::FixedHeader {
        &self.header
    }

    pub fn user_data(&self) -> &HashMap<String, String> {
        &self.user_data
    }

    pub fn record_count(&self) -> u64 {
        self.record_count
    }

    pub fn read(&mut self, _opts: stef_core::ReadOptions) -> Result<(), stef_core::errors::StefError> {
        let _ = &self.state;

        let mut len_buf = [0u8; 8];
        match self.source.read_exact(&mut len_buf) {
            Ok(()) => {}
            Err(e) if e.kind() == io::ErrorKind::UnexpectedEof => return Err(io::Error::from(io::ErrorKind::UnexpectedEof).into()),
            Err(e) => return Err(e.into()),
        }

        let rec_len = u64::from_le_bytes(len_buf) as usize;
        if rec_len > Self::MAX_RECORD_SIZE {
            return Err(stef_core::errors::StefError::message(format!(
                "record too large: {rec_len}"
            )));
        }
        let mut payload = vec![0u8; rec_len];
        self.source.read_exact(&mut payload)?;

        let (rec, _): ({{.StructName}}, usize) = bincode::serde::decode_from_slice(&payload, bincode::config::standard())
            .map_err(|e| stef_core::errors::StefError::message(format!("decode failed: {e}")))?;

        self.record = rec;
        self.record_count += 1;
        Ok(())
    }

    pub fn next_frame(&mut self) -> Result<(), stef_core::errors::StefError> {
        Ok(())
    }

    pub fn schema(&self) -> Option<&stef_core::schema::WireSchema> {
        self.schema.as_ref()
    }
}
