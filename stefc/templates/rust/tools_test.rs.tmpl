#[cfg(test)]
mod tools_tests {
    use rand::SeedableRng;
    use crate::*;
    use std::fs;
    use std::io;
    use std::path::PathBuf;
    use std::process::Command;
    use std::time::{SystemTime, UNIX_EPOCH};

    fn run_go_test_tool(in_dir: &PathBuf, args: &[&str]) -> Result<(), String> {
        let mut cmd = Command::new("go");
        cmd.arg("test")
            .arg("-run")
            .arg("TestTool")
            .args(args)
            .env("CGO_ENABLED", "0")
            .current_dir(in_dir);
        let out = cmd.output().map_err(|e| format!("failed to run go test: {e}"))?;
        if !out.status.success() {
            return Err(format!(
                "go test failed: {}{}",
                String::from_utf8_lossy(&out.stdout),
                String::from_utf8_lossy(&out.stderr)
            ));
        }
        Ok(())
    }

    fn go_pkg_dir() -> Option<PathBuf> {
        let package_name = "{{ .PackageName }}";
        let manifest_dir = PathBuf::from(env!("CARGO_MANIFEST_DIR")).canonicalize().ok()?;

        for dir in manifest_dir.ancestors() {
            let candidate = dir
                .join("stefc")
                .join("generator")
                .join("testdata")
                .join("out")
                .join(format!("{}.stef", package_name))
                .join(package_name);
            if candidate.join("tools_test.go").exists() {
                return Some(candidate);
            }
            let candidate = dir.join("go").join("otel").join(package_name);
            if candidate.join("tools_test.go").exists() {
                return Some(candidate);
            }
        }
        None
    }

    // diff_data compares two STEF files containing records of the specified root struct.
    fn diff_data(root_struct: &str, fname1: &str, fname2: &str) -> Result<(), String> {
        let mut file1 = std::fs::File::open(fname1).map_err(|e| format!("cannot open {fname1}: {e}"))?;
        let mut file2 = std::fs::File::open(fname2).map_err(|e| format!("cannot open {fname2}: {e}"))?;

        match root_struct {
{{ range $i, $StructName := .RootStructs }}
            "{{$StructName}}" => {
                let mut reader1 = {{$StructName}}Reader::new(&mut file1).map_err(|e| format!("reader1 init: {e}"))?;
                let mut reader2 = {{$StructName}}Reader::new(&mut file2).map_err(|e| format!("reader2 init: {e}"))?;

                loop {
                    let err1 = reader1.read(stef_core::ReadOptions::default());
                    let err2 = reader2.read(stef_core::ReadOptions::default());

                    match (err1, err2) {
                        (Ok(()), Ok(())) => {
                            if !reader1.record.is_equal(&reader2.record) {
                                return Err(format!("record #{} differs", reader1.record_count()));
                            }
                        }
                        (Err(e1), Err(e2)) => {
                            let eof1 = matches!(e1, stef_core::errors::StefError::Io(ref ioe) if ioe.kind() == io::ErrorKind::UnexpectedEof);
                            let eof2 = matches!(e2, stef_core::errors::StefError::Io(ref ioe) if ioe.kind() == io::ErrorKind::UnexpectedEof);
                            if eof1 && eof2 {
                                break;
                            }
                            return Err(format!("read failed: {e1} / {e2}"));
                        }
                        (Err(e), Ok(())) => return Err(format!("{fname2} has more records than {fname1} ({e})")),
                        (Ok(()), Err(e)) => return Err(format!("{fname1} has more records than {fname2} ({e})")),
                    }
                }

                Ok(())
            }
{{end}}
            _ => Err(format!("unsupported root struct: {root_struct}")),
        }
    }

    // copy_data copies records from one STEF file to another for the specified root struct.
    fn copy_data(root_struct: &str, source_fname: &str, dest_fname: &str, include_schema: bool) -> Result<(), String> {
        let mut source_file = std::fs::File::open(source_fname)
            .map_err(|e| format!("cannot open source file {source_fname}: {e}"))?;
        let mut dest_file = std::fs::File::create(dest_fname)
            .map_err(|e| format!("cannot create destination file {dest_fname}: {e}"))?;
        let mut dst = stef_core::WrapChunkWriter::new(&mut dest_file);

        match root_struct {
{{ range $i, $StructName := .RootStructs }}
            "{{$StructName}}" => {
                let mut reader = {{$StructName}}Reader::new(&mut source_file)
                    .map_err(|e| format!("cannot create reader for {source_fname}: {e}"))?;
                let mut opts = stef_core::WriterOptions::default();
                if include_schema {
                    opts.schema = reader.schema().cloned();
                    opts.include_descriptor = true;
                }
                let mut writer = {{$StructName}}Writer::new(&mut dst, opts)
                    .map_err(|e| format!("cannot create writer for {dest_fname}: {e}"))?;

                loop {
                    match reader.read(stef_core::ReadOptions::default()) {
                        Ok(()) => {
                            writer.record.copy_from(&reader.record);
                            writer.write().map_err(|e| format!("write failed: {e}"))?;
                        }
                        Err(stef_core::errors::StefError::Io(ref ioe))
                            if ioe.kind() == io::ErrorKind::UnexpectedEof => break,
                        Err(e) => return Err(format!("read failed: {e}")),
                    }
                }
                writer.flush().map_err(|e| format!("flush failed: {e}"))?;
                Ok(())
            }
{{end}}
            _ => Err(format!("unsupported root struct: {root_struct}")),
        }
    }

    // generate_data generates random records of the specified root struct and writes them to the output file.
    fn generate_data(root_struct: &str, out_file_name: &str, mut seed: u64, record_count: u64, specify_schema: bool) -> Result<(), String> {
        let mut out_file = std::fs::File::create(out_file_name)
            .map_err(|e| format!("cannot create output file {out_file_name}: {e}"))?;
        let mut dst = stef_core::WrapChunkWriter::new(&mut out_file);

        if seed == 0 {
            seed = SystemTime::now()
                .duration_since(UNIX_EPOCH)
                .map_err(|e| format!("clock error: {e}"))?
                .as_nanos() as u64;
        }
        let mut random = rand::rngs::StdRng::seed_from_u64(seed);

        match root_struct {
{{ range $i, $StructName := .RootStructs }}
            "{{$StructName}}" => {
                let mut opts = stef_core::WriterOptions::default();
                if specify_schema {
                    opts.schema = Some({{$StructName}}_wire_schema().map_err(|e| format!("wire schema: {e}"))?);
                }
                let mut writer = {{$StructName}}Writer::new(&mut dst, opts)
                    .map_err(|e| format!("writer init: {e}"))?;

                for _ in 0..record_count {
                    let mut limiter = MutateRandomLimiter::default();
                    writer.record.mutate_random(&mut random, &mut limiter);
                    writer.write().map_err(|e| format!("write failed: {e}"))?;
                }
                writer.flush().map_err(|e| format!("flush failed: {e}"))?;
                Ok(())
            }
{{end}}
            _ => Err(format!("unsupported root struct: {root_struct}")),
        }
    }

    fn go_pkg_shrunk_dir() -> Option<PathBuf> {
        let package_name = "{{ .PackageName }}";
        let manifest_dir = PathBuf::from(env!("CARGO_MANIFEST_DIR")).canonicalize().ok()?;

        for dir in manifest_dir.ancestors() {
            let candidate = dir
                .join("stefc")
                .join("generator")
                .join("testdata")
                .join("out")
                .join(format!("{}.stef", package_name))
                .join("shrunk")
                .join(package_name);
            if candidate.join("tools_test.go").exists() {
                return Some(candidate);
            }
        }
        None
    }

{{ range $i, $StructName := .RootStructs }}
    #[test]
    // Test interoperability between Rust and Go implementations for {{$StructName}}.
    fn test_format_interop_{{$StructName}}() {
        let go_dir = go_pkg_dir().expect("cannot locate Go package directory");

        let temp = go_dir.join("tempdata");
        let _ = fs::create_dir_all(&temp);

        let go_gen_path = format!("tempdata/{{$StructName}}_go_gen_for_rust.stef");
        let rust_copy_from_go = format!("tempdata/{{$StructName}}_rust_copy_from_go.stef");

        run_go_test_tool(
            &go_dir,
            &[
                "-root={{$StructName}}",
                "-generate",
                "-records=1000",
                "-out",
                &go_gen_path,
            ],
        )
        .expect("go generate");

        copy_data(
            "{{$StructName}}",
            &go_dir.join(&go_gen_path).to_string_lossy(),
            &go_dir.join(&rust_copy_from_go).to_string_lossy(),
            false,
        )
        .expect("rust copy");

        run_go_test_tool(
            &go_dir,
            &["-root={{$StructName}}", "-diff", &go_gen_path, &rust_copy_from_go],
        )
        .expect("go diff");
    }

    #[test]
    // Test interoperability between this Rust implementation and Go implementations
    // of shrunk (older) version of schema for {{$StructName}}.
    fn test_format_interop_{{$StructName}}_compat() {
        let go_dir = go_pkg_shrunk_dir().expect("cannot locate shrunk Go package directory");

        let temp = go_dir.join("tempdata");
        let _ = fs::create_dir_all(&temp);

        let gen_path = format!("tempdata/{{$StructName}}_go_gen_for_rust.stef");
        let copy_path = format!("tempdata/{{$StructName}}_rust_copy_from_go.stef");

        run_go_test_tool(
            &go_dir,
            &[
                "-root={{$StructName}}",
                "-generate",
                "-withschema",
                "-records=100",
                "-out",
                &gen_path,
            ],
        )
        .expect("go generate");

        copy_data(
            "{{$StructName}}",
            &go_dir.join(&gen_path).to_string_lossy(),
            &go_dir.join(&copy_path).to_string_lossy(),
            true,
        )
        .expect("rust copy");

        run_go_test_tool(
            &go_dir,
            &["-root={{$StructName}}", "-diff", &gen_path, &copy_path],
        )
        .expect("go diff");
    }
{{end}}
}
