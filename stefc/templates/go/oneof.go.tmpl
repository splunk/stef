        return d.{{.name}}Decoder.Decode(dst.{{.name}}Ptr())
        {{- else}}
        {{- if .Type.DictName}}
        v := dst.{{.name}}Ptr()
        err := d.{{.name}}Decoder.Decode(&v)
        if err != nil {
